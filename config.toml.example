[elevenlabs]
api_key = ""           # or set ELEVENLABS_API_KEY env var
default_voice_id = "Adam"
model_id = "eleven_multilingual_v2"

# Optional: enable mood-based tag expansion (per-sentence LLM call, cached on disk).
# Set one of:
#   ANTHROPIC_API_KEY   → uses claude-haiku-4-5 (~$0.0001/call)
#   GEMINI_API_KEY      → uses gemini-2.5-flash-lite
# If both are set, Anthropic is used by default. Override with MOOD_PROVIDER=gemini.

[library]
path = "res"           # folder containing clip_index.json and images

[cache]
path = "cache"

[output]
path = "output"

[compose]
pause_duration = 0.3   # seconds of silence between segments

[sfx]
path = "sfx"           # folder containing sound effect audio files
